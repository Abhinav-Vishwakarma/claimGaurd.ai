# ================================================================
# ClaimGuard.ai — Backend Environment Variables
# ================================================================
# Copy this file to .env and fill in the values.
#   cp .env.example .env
#
# ⚠️  Never commit your real .env file to version control.
# ================================================================


# ----------------------------------------------------------------
# 🌐 APP CONFIG
# ----------------------------------------------------------------
PORT=5000
NODE_ENV=development

# Public URL of the frontend (used for CORS allow-list)
APP_URL=http://localhost:5173


# ----------------------------------------------------------------
# 🗄️ POSTGRESQL (Prisma)
# ----------------------------------------------------------------
# Option A — Connection string (recommended, supports pooling)
#   Supabase pooled connection:
DATABASE_URL="postgresql://user:password@host:6543/dbname?pgbouncer=true"

# Direct connection (used by Prisma migrations — not pooled)
DIRECT_URL="postgresql://user:password@host:5432/dbname"

# Option B — Individual fields (uncomment if not using a connection string)
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=strongpassword
# DB_NAME=claimgaurd_db


# ----------------------------------------------------------------
# ⚡ REDIS (Cache + BullMQ job queues)
# ----------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379

# Full Redis URL (overrides HOST/PORT when set — use for cloud Redis e.g. Upstash)
# REDIS_URL="rediss://default:<password>@<host>:<port>"


# ----------------------------------------------------------------
# 🧠 QDRANT (Vector Database)
# ----------------------------------------------------------------
# Cloud cluster URL (from qdrant.tech dashboard)
QDRANT_URL=https://your-cluster-id.region.aws.cloud.qdrant.io

# API key for the cluster
QDRANT_API_KEY=your_qdrant_api_key

# Name of the collection where claim-rule embeddings are stored
QDRANT_COLLECTION=claims_embeddings

# Local alternative (uncomment for local Docker Qdrant):
# QDRANT_URL=http://localhost:6333


# ----------------------------------------------------------------
# 🤖 GOOGLE AI (Gemini — OCR, Vision, Embeddings)
# ----------------------------------------------------------------
# Get your key from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key

# Embedding model used for Qdrant indexing and similarity search
GOOGLE_EMBEDDING_MODEL=gemini-embedding-001

# Default Gemini model used for text extraction fallback
GOOGLE_DEFAULT_MODEL=gemini-2.5-flash


# ----------------------------------------------------------------
# ⚡ GROQ (LLaMA3 — Fraud Detection LLM)
# ----------------------------------------------------------------
# Get your key from: https://console.groq.com
GROQ_API_KEY=your_groq_api_key

# Model used for fraud detection (upcoding + unbundling analysis)
GROQ_DEFAULT_MODEL=llama-3.3-70b-versatile


# ----------------------------------------------------------------
# 🔐 JWT AUTHENTICATION
# ----------------------------------------------------------------
# Use a long, random string (minimum 32 characters)
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_strong_random_secret_at_least_32_chars

# Token expiry for access tokens
JWT_EXPIRES_IN=7d

# (Optional) Separate secret for refresh tokens
# JWT_REFRESH_SECRET=replace_with_another_strong_random_secret
# JWT_REFRESH_EXPIRES_IN=30d


# ----------------------------------------------------------------
# 📁 FILE UPLOADS (UploadThing)
# ----------------------------------------------------------------
# Get these from: https://uploadthing.com/dashboard
UPLOADTHING_TOKEN=your_uploadthing_token
UPLOADTHING_SECRET=your_uploadthing_secret
UPLOADTHING_APP_ID=your_uploadthing_app_id


# ----------------------------------------------------------------
# 🧪 FEATURE FLAGS
# ----------------------------------------------------------------
# Set to "false" to disable a subsystem for local testing
ENABLE_CACHE=true
ENABLE_QUEUE=true
ENABLE_RAG=true
