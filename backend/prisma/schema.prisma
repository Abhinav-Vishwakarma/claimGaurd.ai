generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  CLIENT
  HOSPITAL
  ADMIN
}

model User {
  id            String             @id @default(uuid())
  email         String             @unique
  passwordHash  String
  name          String?
  role          Role               @default(CLIENT)
  refreshTokens RefreshToken[]
  memberProfile MemberProfile?
  claims        Claim[]
  vaultItems    MedicalVaultItem[]
  appeals       Appeal[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([role])
}

model RefreshToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

enum PlanType {
  PPO
  HMO
}

enum ClaimStatus {
  pending
  approved
  denied
}

enum VaultItemType {
  prescription
  bill
  lab_report
}

enum EOBStatus {
  processed
  appealed
}

enum AppealStatus {
  drafted
  submitted
  resolved
}

model MemberProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  memberId        String   @unique
  planType        PlanType @default(PPO)
  deductibleTotal Float    @default(0)
  deductibleMet   Float    @default(0)
  policyActive    Boolean  @default(true)
  premiumPaid     Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Claim {
  id        String      @id @default(uuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider  String
  amount    Float
  date      DateTime
  status    ClaimStatus @default(pending)
  eob       EOBRecord?
  appeals   Appeal[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model EOBRecord {
  id                    String    @id @default(uuid())
  claimId               String    @unique
  claim                 Claim     @relation(fields: [claimId], references: [id], onDelete: Cascade)
  dateOfService         DateTime
  billedAmount          Float
  allowedAmount         Float
  paidAmount            Float
  patientResponsibility Float
  finalStatus           EOBStatus @default(processed)
  createdAt             DateTime  @default(now())
}

model MedicalVaultItem {
  id            String        @id @default(uuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  type          VaultItemType
  fileName      String
  url           String
  publicId      String?
  uploadDate    DateTime      @default(now())
  extractedData Json?
  extractedAt   DateTime?
  createdAt     DateTime      @default(now())
}

model Appeal {
  id        String       @id @default(uuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  claimId   String
  claim     Claim        @relation(fields: [claimId], references: [id], onDelete: Cascade)
  status    AppealStatus @default(drafted)
  content   String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}
